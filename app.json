{
  "expo": {
    "name": "G-Fit",
    "slug": "GTKF",
    "scheme": "GTKF",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-appstore-bg.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/G-FIT-2.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.g-fit",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthShareUsageDescription": "G-fit uses your step count to track your daily activity and family fitness goals.",
        "NSHealthUpdateUsageDescription": "G-fit saves your step data to help you and your family stay on track with your fitness goals.",
        "NSMotionUsageDescription": "G-fit uses your device's motion sensors to count your steps and track your daily activity."
      },
      "splash": {
        "image": "./assets/G-FIT-2.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "app.gfit",
      "permissions": ["android.permission.ACTIVITY_RECOGNITION"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/G-FIT-2.png",
          "color": "#ffffff"
        }
      ],
      "expo-video",
      "react-native-iap"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "da662151-4335-4421-8da6-a5de45456725"
      }
    }
  }
}
