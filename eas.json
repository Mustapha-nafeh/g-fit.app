{
  "cli": {
    "version": ">= 16.20.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "https://backend.g-fit.app/api/v1",
        "STORAGE_BASE_URL": "https://backend.g-fit.app/storage"
      },
      "ios": {
        "cache": {
          "disabled": true
        }
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "https://backend.g-fit.app/api/v1",
        "STORAGE_BASE_URL": "https://backend.g-fit.app/storage"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_BASE_URL": "https://backend.g-fit.app/api/v1",
        "STORAGE_BASE_URL": "https://backend.g-fit.app/storage"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
